---
import { personal } from '../data/cv';
---

<header>
  <nav class="nav" aria-label="Main navigation">
    <div class="container nav__inner">

      <!-- Logo -->
      <a href="#hero" class="nav__logo" aria-label="Taqi Eldeen — Home">
        <span>TQ</span>.dev
      </a>

      <!-- Desktop links -->
      <ul class="nav__links" role="list">
        <li><a href="#projects"    class="nav__link">Work</a></li>
        <li><a href="#about"       class="nav__link">About</a></li>
        <li><a href="#skills"      class="nav__link">Skills</a></li>
        <li><a href="#experience"  class="nav__link">Experience</a></li>
        <li><a href="#certifications" class="nav__link">Certs</a></li>
        <li><a href="#contact"     class="nav__link">Contact</a></li>
      </ul>

      <!-- Right side -->
      <div class="nav__right">
        <a
          href={`mailto:${personal.email}`}
          class="btn btn-primary"
          aria-label="Send email to hire Taqi Eldeen"
        >
          Hire me
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>

        <button
          id="nav-toggle"
          class="nav__toggle"
          aria-label="Toggle mobile menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <span></span><span></span><span></span>
        </button>
      </div>

    </div>
  </nav>

  <!-- Mobile overlay -->
  <div id="mobile-nav" class="mobile-nav" role="dialog" aria-label="Mobile navigation">
    <nav>
      <ul class="mobile-nav__links" role="list">
        <li><a href="#projects"       class="mobile-nav__link">Work</a></li>
        <li><a href="#about"          class="mobile-nav__link">About</a></li>
        <li><a href="#skills"         class="mobile-nav__link">Skills</a></li>
        <li><a href="#experience"     class="mobile-nav__link">Experience</a></li>
        <li><a href="#certifications" class="mobile-nav__link">Certs</a></li>
        <li><a href="#contact"        class="mobile-nav__link">Contact</a></li>
      </ul>
    </nav>
    <div class="mobile-nav__bottom">
      <a href={personal.github}   target="_blank" rel="noopener" class="mobile-social">GitHub</a>
      <a href={personal.linkedin} target="_blank" rel="noopener" class="mobile-social">LinkedIn</a>
      <a href={`mailto:${personal.email}`}                       class="mobile-social">Email</a>
    </div>
  </div>
</header>
